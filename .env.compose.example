TZ=Asia/Shanghai

# Published ports (host -> container)
BACKEND_PORT=1235
FRONTEND_PORT=5173
MYSQL_PORT=3307
REDIS_PORT=6380
EMBEDDING_PORT=8081

# MySQL bootstrap
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=ai_list

# Embedding container
EMBEDDING_IMAGE=ghcr.io/huggingface/text-embeddings-inference:cpu-latest
EMBEDDING_MODEL_ID=BAAI/bge-m3
